# Orakel - Polymarket BTC Multi-Timeframe Trading Bot
# Minimal configuration for local Docker deployment

# Trading mode: true = paper trading (simulated), false = live trading
PAPER_MODE=true

# Active markets (comma-separated)
ACTIVE_MARKETS=BTC-5m,BTC-15m

# Optional: API port (default: 9999)
# API_PORT=9999

# Optional: CORS origins for API access (comma-separated, or * for wildcard)
# For Docker Compose with separate web service, use: http://localhost:9998
CORS_ORIGIN=*

# Optional: Log level (debug, info, warn, error, silent)
# LOG_LEVEL=info

# Optional: Bearer token for API authentication (leave empty for local access)
# API_TOKEN=your-secret-token

# Optional: Private key for live trading (64-char hex, no 0x prefix)
# PRIVATE_KEY=

# Optional: Auto-redeem settled positions automatically (requires PRIVATE_KEY)
# AUTO_REDEEM_ENABLED=false
# AUTO_REDEEM_INTERVAL_MS=300000

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/orakel

# -----------------------------------------------------------------------------
# Docker Compose only (web service)
# -----------------------------------------------------------------------------

# Frontend port for web service
# WEB_PORT=9998

# API base URL for web service (internal Docker network)
# VITE_API_BASE_URL=http://bot:9999
