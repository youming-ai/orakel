# Orakel - Polymarket 15-min Crypto Trading Bot
# Minimal configuration for local Docker deployment

# Trading mode: true = paper trading (simulated), false = live trading
PAPER_MODE=true

# Active markets (comma-separated)
ACTIVE_MARKETS=BTC,ETH,SOL,XRP

# Optional: API port (default: 9999)
# API_PORT=9999

# Optional: Log level (debug, info, warn, error, silent)
# LOG_LEVEL=info

# Optional: Bearer token for API authentication (leave empty for local access)
# API_TOKEN=your-secret-token

# Optional: Private key for live trading (64-char hex, no 0x prefix)
# PRIVATE_KEY=

# Optional: Auto-redeem settled positions automatically (requires PRIVATE_KEY)
# AUTO_REDEEM_ENABLED=false
# AUTO_REDEEM_INTERVAL_MS=1800000  # Check interval in milliseconds (30 minutes = 1800000)
