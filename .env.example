# Orakel - BTC 5-Min Up/Down Polymarket Trading Bot
# Copy to .env and fill in your values

# Trading mode: true = paper trading (simulated), false = live trading
PAPER_MODE=true

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/orakel

# Wallet private key for live trading (hex with 0x prefix)
# Required only when PAPER_MODE=false
# POLYMARKET_PRIVATE_KEY=0x...

# Bearer token for API authentication (default: empty, optional for local dev)
# API_TOKEN=

# API server port (default: 9999)
# PORT=9999

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
