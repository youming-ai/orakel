{
	"name": "@orakel/bot",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"start": "bun run --env-file ../../.env src/index.ts",
		"dev": "bun run --env-file ../../.env --watch src/index.ts",
		"typecheck": "tsc --noEmit",
		"typecheck:ci": "tsc --noEmit -p tsconfig.check.json",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@orakel/shared": "workspace:*",
		"@polymarket/clob-client": "^5.8.0",
		"drizzle-orm": "^0.45.1",
		"ethers": "^5.8.0",
		"hono": "^4.12.6",
		"postgres": "^3.4.8",
		"ws": "^8.19.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/ws": "^8.18.1",
		"drizzle-kit": "^0.31.9",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
